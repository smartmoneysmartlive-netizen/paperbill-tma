// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  telegramId    BigInt   @unique
  username      String?
  firstName     String?
  lastName      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  wallet        Wallet?
  transactions  Transaction[]
  tokenHistory  TokenTransaction[]
}

model Wallet {
  id            String   @id @default(uuid())
  userId        String   @unique
  nairaBalance  Int      @default(0) // Balance in Kobo or Naira (using Int for precision)
  paperBalance  Int      @default(0)
  walletAddress String?  @unique // Future crypto migration
  updatedAt     DateTime @updatedAt
  
  user          User     @relation(fields: [userId], references: [id])
}

enum TransactionType {
  AIRTIME
  DATA
  CABLE_TV
  ELECTRICITY
  EDUCATION
  CREDIT
  DEBIT
  REWARD
}

enum TransactionStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
  REFUNDED
}

enum Currency {
  NGN
  PAPER
}

model Transaction {
  id            String            @id @default(uuid())
  userId        String
  type          TransactionType
  amount        Int
  apiCost       Int?              // Wholesale cost for profit tracking
  profit        Int?              // Calculated margin
  currency      Currency          @default(NGN)
  status        TransactionStatus @default(PENDING)
  reference     String            @unique
  provider      String?           // e.g., "cheapdatahub", "vtung"
  metadata      Json?
  apiResponse   Json?             // Raw provider response for debugging
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  
  user          User              @relation(fields: [userId], references: [id])
}

enum TokenAction {
  EARN
  SPEND
  STAKE
}

model TokenTransaction {
  id            String      @id @default(uuid())
  userId        String
  amount        Int
  type          TokenAction
  source        String?     // e.g., "referral", "purchase_bonus"
  createdAt     DateTime    @default(now())
  
  user          User        @relation(fields: [userId], references: [id])
}

model AuditLog {
  id            String   @id @default(uuid())
  userId        String?
  action        String   // e.g. "WALLET_LOCK", "VTU_API_CALL"
  level         LogLevel @default(INFO)
  metadata      Json?    // Request/Response payloads
  ipAddress     String?
  createdAt     DateTime @default(now())
}

enum LogLevel {
  INFO
  WARN
  ERROR
  CRITICAL
}

model SystemSetting {
  id            String   @id @default(uuid())
  key           String   @unique
  value         String
  description   String?
  updatedAt     DateTime @updatedAt
}
